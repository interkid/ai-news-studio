# このファイルを .env にコピーして値を埋めること。詳細な取得手順は manual.md を参照。
# 現時点(M2)で必須なのは ANTHROPIC_API_KEY のみ。他は未設定でもフォールバックで動作する。

# --- LLM(必須・M2から) ---
ANTHROPIC_API_KEY=

# --- 画像生成(任意・M2から。未設定時は固定背景にフォールバック) ---
FAL_KEY=
IMAGE_DAILY_LIMIT=5

# --- LLM呼び出し日次上限 ---
DAILY_LLM_CALL_LIMIT=30

# --- VOICEVOX(任意・M2から。未起動時は概算秒数にフォールバック) ---
VOICEVOX_URL=http://localhost:50021
VOICEVOX_SPEAKER_FOX=11
VOICEVOX_SPEAKER_RABBIT=46

# --- LINE(M3から) ---
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_ADMIN_USER_ID=

# --- Cloudflare R2(M3から) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# --- Cloudflare Workers + KV(M3から) ---
CF_KV_NAMESPACE_ID=
CF_API_TOKEN=

# --- TikTok(M4から) ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=
